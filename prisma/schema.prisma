generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ShopifySession {
  id          String   @id @default(cuid())
  shopDomain  String   @unique
  accessToken String
  scopes      String
  apiVersion  String
  installedAt DateTime
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model ShopifyOAuthState {
  id         String   @id @default(cuid())
  stateHash  String   @unique
  shopDomain String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([shopDomain])
  @@index([expiresAt])
}

model ShopifyStore {
  id               String    @id @default(cuid())
  shopDomain       String    @unique
  name             String
  email            String?
  currency         String
  countryCode      String?
  timezone         String?
  planName         String?
  primaryDomain    String?
  shopifyCreatedAt DateTime?
  syncedAt         DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ShopifyProductSync {
  id               String    @id @default(cuid())
  shopDomain       String
  shopifyProductId String
  title            String
  handle           String
  status           String
  vendor           String?
  productType      String?
  tags             String
  publishedAt      DateTime?
  rawPayload       Json?
  syncedAt         DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([shopDomain, shopifyProductId])
  @@index([shopDomain])
}

model ShopifyCollectionSync {
  id                  String    @id @default(cuid())
  shopDomain          String
  shopifyCollectionId String
  title               String
  handle              String
  collectionType      String
  publishedAt         DateTime?
  rawPayload          Json?
  syncedAt            DateTime
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([shopDomain, shopifyCollectionId])
  @@index([shopDomain])
}

model ShopifyInventorySync {
  id              String    @id @default(cuid())
  shopDomain      String
  inventoryItemId String
  locationId      String
  available       Int?
  updatedAtSource DateTime?
  syncedAt        DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([shopDomain, inventoryItemId, locationId])
  @@index([shopDomain])
}

model ShopifyLocationSync {
  id                String   @id @default(cuid())
  shopDomain        String
  shopifyLocationId String
  name              String
  active            Boolean
  countryCode       String?
  provinceCode      String?
  city              String?
  address1          String?
  syncedAt          DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shopDomain, shopifyLocationId])
  @@index([shopDomain])
}

model ShopifyOrderSync {
  id                String    @id @default(cuid())
  shopDomain        String
  shopifyOrderId    String
  orderName         String
  financialStatus   String?
  fulfillmentStatus String?
  currency          String
  totalPrice        String
  customerEmail     String?
  processedAt       DateTime?
  rawPayload        Json?
  syncedAt          DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([shopDomain, shopifyOrderId])
  @@index([shopDomain])
}

model ShopifyCustomerSync {
  id                String   @id @default(cuid())
  shopDomain        String
  shopifyCustomerId String
  email             String?
  firstName         String?
  lastName          String?
  ordersCount       Int
  totalSpent        String
  currency          String?
  rawPayload        Json?
  syncedAt          DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shopDomain, shopifyCustomerId])
  @@index([shopDomain])
}

model ShopifySyncRun {
  id               String    @id @default(cuid())
  shopDomain       String
  status           String
  startedAt        DateTime
  completedAt      DateTime?
  durationMs       Int?
  productsCount    Int       @default(0)
  collectionsCount Int       @default(0)
  inventoryCount   Int       @default(0)
  locationsCount   Int       @default(0)
  ordersCount      Int       @default(0)
  customersCount   Int       @default(0)
  warnings         Json?
  errorCode        String?
  errorMessage     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([shopDomain])
  @@index([shopDomain, status])
}

model ProductImport {
  importId            String   @id
  tenantId            String
  storeId             String
  shopDomain          String?
  sourcePlatform      String
  externalProductId   String
  sourceUrl           String?
  supplierName        String?
  status              String
  pipelineStatus      String
  idempotencyKey      String
  idempotencyBehavior String
  duplicate           Boolean  @default(false)
  forced              Boolean  @default(false)
  parentImportId      String?
  productDraftId      String?
  approvalId          String?
  auditReference      String?
  failureStage        String?
  failureCode         String?
  failureMessage      String?
  warnings            Json
  payload             Json
  resultSnapshot      Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  completedAt         DateTime?

  @@index([tenantId, storeId])
  @@index([tenantId, storeId, sourcePlatform, externalProductId])
  @@index([tenantId, storeId, idempotencyKey])
  @@index([status])
  @@index([approvalId])
  @@index([productDraftId])
  @@index([parentImportId])
}

model ProductDraft {
  id                 String   @id
  tenantId           String
  storeId            String
  shopDomain         String?
  status             String
  version            Int
  sourceType         String
  sourceId           String
  sourceReferenceKey String
  supplierId         String?
  supplierProductId  String?
  idempotencyKey     String?
  title              String
  brand              String?
  category           String?
  productType        String?
  currency           String?
  riskLevel          String?
  approvalId         String?
  payload            Json
  createdAt          DateTime
  updatedAt          DateTime @updatedAt
  archivedAt         DateTime?

  @@unique([tenantId, storeId, idempotencyKey])
  @@unique([tenantId, storeId, sourceReferenceKey])
  @@index([tenantId, storeId])
  @@index([tenantId, storeId, status])
  @@index([tenantId, storeId, sourceType])
  @@index([tenantId, storeId, riskLevel])
  @@index([approvalId])
}

model ApprovalRecord {
  id                    String    @id
  tenantId              String
  storeId               String
  shopDomain            String?
  proposalId            String
  workflowId            String?
  title                 String
  status                String
  riskLevel             String
  requestedBy           String
  decidedBy             String?
  decisionReason        String?
  requiresHumanApproval Boolean
  executionEnabled      Boolean
  source                String
  version               Int
  payload               Json
  createdAt             DateTime
  requestedAt           DateTime
  decidedAt             DateTime?
  updatedAt             DateTime  @updatedAt

  @@index([tenantId, storeId])
  @@index([tenantId, storeId, status])
  @@index([tenantId, storeId, proposalId])
  @@index([tenantId, storeId, requestedAt])
}

model AuditRecord {
  id            String   @id
  tenantId      String
  storeId       String
  shopDomain    String?
  eventType     String
  entityType    String
  entityId      String
  actor         String
  summary       String
  source        String
  sequence      Int
  correlationId String?
  activityType  String?
  status        String?
  details       Json
  payload       Json
  occurredAt    DateTime
  recordedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([tenantId, storeId])
  @@index([tenantId, storeId, entityType, entityId])
  @@index([tenantId, storeId, eventType])
  @@index([tenantId, storeId, correlationId])
  @@index([tenantId, storeId, occurredAt])
}
